   "source": [
    "# Create a list of all headlines as one big string\n",
    "all_headlines = ' '.join(df['headline'].astype(str))\n",
    "\n",
    "# Count vectorizer to find top 20 words\n",
    "vectorizer = CountVectorizer(stop_words='english', max_features=20)\n",
    "word_counts = vectorizer.fit_transform(df['headline'])\n",
    "\n",
    "# Get feature names and their sums\n",
    "words = vectorizer.get_feature_names_out()\n",
    "counts = word_counts.toarray().sum(axis=0)\n",
    "\n",
    "# Create DataFrame and sort\n",
    "word_freq = pd.DataFrame({'word': words, 'count': counts})\n",
    "word_freq = word_freq.sort_values('count', ascending=False)\n",
    "\n",
    "print(\"Top 20 words in headlines:\")\n",
    "print(word_freq)"
   ]
  },
